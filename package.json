{
  "name": "frontend-mining-tycoon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:fixed": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,css}\" index.html",
    "format:fix": "prettier --write \"src/**/*.{js,css}\" index.html",
    "format:check": "prettier --check \"src/**/*.{js,css}\" index.html",
    "check:changed-lines-coverage": "node ./scripts/check_changed_lines_coverage.mjs",
    "mutation": "stryker run",
    "mutation:check": "stryker run --dryRunOnly",
    "audit:health": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\code_health_audit.ps1",
    "clean:audit": "eslint src --max-warnings=0 && knip --no-progress --no-config-hints --include files,dependencies,unresolved",
    "check:all": "npm run clean:audit && npm run format:check && npm run test -- --run && npm run build && npm audit --omit=dev",
    "test": "vitest run --environment jsdom --silent=passed-only",
    "test:ui": "vitest run --environment jsdom --silent=passed-only --run src/ui src/layout-css.test.js src/tooltip-parity.test.js",
    "test:services": "vitest run --environment jsdom --silent=passed-only --run src/services src/meta src/utils",
    "test:flows": "vitest run --environment jsdom --silent=passed-only --run src/main.test.js src/layout-controls.test.js src/async-session-flow.test.js src/security-rendering.test.js",
    "test:contract": "vitest run --environment jsdom --silent=passed-only --run src/meta/meta-manager.test.js src/main.test.js",
    "test:fast": "npm run test:services && npm run test:ui",
    "test:watch": "vitest --environment jsdom --silent=passed-only",
    "test:coverage": "vitest run --coverage --environment jsdom --silent=passed-only"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@stryker-mutator/core": "^8.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jsdom": "^28.1.0",
    "knip": "^5.63.1",
    "prettier": "^3.5.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
