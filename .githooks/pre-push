#!/usr/bin/env sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/pre_push_gate.ps1
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/pre_push_gate.ps1
fi

echo "ERROR: PowerShell was not found. Unable to run frontend pre-push gate." >&2
exit 1
